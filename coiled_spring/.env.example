# ── Google Ads API ──────────────────────────────────────────────────────────
# https://developers.google.com/google-ads/api/docs/get-started/introduction
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=1234567890   # no dashes

# ── NewsAPI ─────────────────────────────────────────────────────────────────
# Free tier at https://newsapi.org/register (100 req/day)
# If omitted, GDELT (free, no key) is used as fallback
NEWS_API_KEY=your_newsapi_key_here

# ── FRED API (Federal Reserve Economic Data) ─────────────────────────────────
# Free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Weather location (Open-Meteo — no key required) ──────────────────────────
# Defaults to Austin, TX. Set to your primary client market.
WEATHER_LAT=30.2672
WEATHER_LON=-97.7431
